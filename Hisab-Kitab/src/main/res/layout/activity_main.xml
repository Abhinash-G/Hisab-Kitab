<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Title - Material Design Header -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/titleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/HOME_PAGE_HEADER"
        android:textAppearance="?attr/textAppearanceHeadline5"
        android:textColor="?attr/colorPrimary"
        android:layout_marginTop="8dp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"
        android:padding="12dp" />

    <!-- Keywords Input -->
    <EditText
        android:id="@+id/keywordInput"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="@string/KEYWORD_SUGGESTION"
        android:inputType="text"
        android:layout_marginBottom="12dp"
        android:padding="12dp" />

    <!-- Date Selection Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/startDateButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/SELECT_START_DATE"
            android:contentDescription="@string/SELECT_START_DATE"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/endDateButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/SELECT_END_DATE"
            android:contentDescription="@string/SELECT_END_DATE"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- Action Buttons Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/startScanButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/START_SCAN"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/sendButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/SEND_BUTTON"
            android:layout_marginHorizontal="4dp" />

        <Button
            android:id="@+id/resetButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/RESET_BUTTON"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:visibility="gone"
        android:layout_marginBottom="16dp" />

    <!-- Feedback ScrollView -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/feedbackText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/READY_TO_SCAN"
            android:textSize="14sp"
            android:scrollbars="vertical"
            android:padding="8dp" />

    </ScrollView>

</LinearLayout>
